    "expo-localization": "^55.0.13",
    "expo-router": "~55.0.0",
    "expo-secure-store": "^55.0.13",
    "expo-sqlite": "~55.0.0",
    "expo-status-bar": "~55.0.6",
    "i18n-js": "^4.5.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-mmkv": "^3.3.3",
    "react-native-reanimated": "4.2.1",
